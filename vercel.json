{
  "rewrites": [
    { "source": "/:slug", "destination": "/api/:slug" }
  ],
  "redirects": [
    { "source": "/", "destination": "https://bluepad.ai", "statusCode": 302 }
  ],
  "headers": [
    {
      "source": "/:slug",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}
